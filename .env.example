# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://xxxxxxxxxxxx.supabase.co/storage/v1/object/public/property-images

# Admin auth
ADMIN_PASSWORD=your_strong_password_here
JWT_SECRET=your_random_32_character_secret_here

# Secret admin URL (panel at /mouad-gestion-2025 — /admin returns 404)
ADMIN_SECRET_PATH=mouad-gestion-2025
NEXT_PUBLIC_ADMIN_PATH=mouad-gestion-2025

# Formspree (contact form)
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id
